# Server Configuration
PORT=8080

# Database Configuration
# Format: postgresql://user:password@host:port/database
# Or: host=localhost user=postgres password=postgres dbname=axumbackend
DATABASE_URL="postgresql://postgres:password@localhost:5432/axumbackend"

# Connection Pool Configuration
# Maximum number of connections in the pool (default: 20)
DB_POOL_MAX_SIZE=20

# Timeout for acquiring a connection in seconds (default: 30)
DB_POOL_CONNECTION_TIMEOUT=30
